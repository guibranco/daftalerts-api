{
  "ConnectionStrings": {
    "Default": "Data Source=/var/lib/daftalerts/daftalerts.db;Cache=Shared;Foreign Keys=true"
  },
  "Auth": {
    "ApiToken": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Geocoding": {
    "Provider": "GoogleThenNominatim",
    "GoogleApiKey": "",
    "NominatimUserAgent": "DaftAlerts/1.0 (contact: you@example.com)",
    "CacheTtlDays": 365
  },
  "Retention": {
    "RawEmailDays": 90
  },
  "Database": {
    "AutoMigrate": false
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/daftalerts/api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-ddTHH:mm:ss.fffZ} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  }
}
